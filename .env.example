# Firebase client config (do not commit real keys)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# AI endpoint (backend URL)
VITE_AI_ENDPOINT=http://localhost:8000
VITE_AI_DIFFICULTY=expert
# Optional tuning
# VITE_AI_DEPTH=6
# VITE_AI_TIME=2.0

# Optional: base path for static hosting (e.g. /your-repo-name/)
# VITE_BASE_PATH=/ChessRider/

# Optional: local dev proxy target for /ai routes
# VITE_DEV_AI_PROXY_TARGET=http://localhost:8000
