rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isBotProfile(uid, data) {
      return data.isBot == true &&
        data.uid == uid &&
        uid.matches('bot_.*');
    }

    function isValidHumanDisplayName(displayName) {
      return displayName is string &&
        displayName == displayName.trim() &&
        displayName.size() > 0 &&
        displayName.size() <= 40 &&
        !displayName.matches('.*\\/.*');
    }

    function hasValidHumanUsernameFields(data, uid) {
      return data.uid == uid &&
        isValidHumanDisplayName(data.displayName) &&
        data.usernameKey is string &&
        data.usernameKey == data.displayName.lower();
    }

    function matchingUsernameClaimAfter(uid) {
      return hasValidHumanUsernameFields(request.resource.data, uid) &&
        existsAfter(/databases/$(database)/documents/usernames/$(request.resource.data.usernameKey)) &&
        getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.usernameKey)).data.uid == uid &&
        getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.usernameKey)).data.displayName == request.resource.data.displayName;
    }

    function usernameFieldsChanged() {
      return request.resource.data.displayName != resource.data.displayName ||
        request.resource.data.usernameKey != resource.data.usernameKey;
    }

    function isMatchStatUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'rating',
        'wins',
        'losses',
        'draws',
        'updatedAt'
      ]);
    }

    function isGameParticipant(gameId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/games/$(gameId)) &&
        (
          get(/databases/$(database)/documents/games/$(gameId)).data.whiteId == request.auth.uid ||
          get(/databases/$(database)/documents/games/$(gameId)).data.blackId == request.auth.uid
        );
    }

    function isMoveStateUpdate() {
      return request.resource.data.fen != resource.data.fen;
    }

    function hasValidMoveSeqTransition() {
      return request.resource.data.moveSeq is int &&
        request.resource.data.lastMove is map &&
        request.resource.data.lastMove.seq is int &&
        request.resource.data.lastMove.seq == request.resource.data.moveSeq &&
        (
          (resource.data.moveSeq is int && request.resource.data.moveSeq == resource.data.moveSeq + 1) ||
          (!(resource.data.moveSeq is int) && request.resource.data.moveSeq == 1)
        );
    }

    function isValidUsernameClaim(usernameKey, data) {
      return data.keys().hasOnly([
          'uid',
          'displayName',
          'createdAt',
          'updatedAt'
        ]) &&
        data.uid == request.auth.uid &&
        isValidHumanDisplayName(data.displayName) &&
        usernameKey == data.displayName.lower();
    }

    function isValidDmParticipants(data) {
      return data.participants is list &&
        data.participants.size() == 2 &&
        data.participants[0] is string &&
        data.participants[1] is string;
    }

    function isDmParticipant(data) {
      return isSignedIn() &&
        isValidDmParticipants(data) &&
        data.participants.hasAny([request.auth.uid]);
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        isBotProfile(uid, request.resource.data) ||
        (isSelf(uid) && matchingUsernameClaimAfter(uid))
      );
      allow update: if isSignedIn() && (
        isBotProfile(uid, request.resource.data) ||
        (
          isSelf(uid) &&
          hasValidHumanUsernameFields(request.resource.data, uid) &&
          (!usernameFieldsChanged() || matchingUsernameClaimAfter(uid))
        ) ||
        isMatchStatUpdate()
      );
    }

    match /usernames/{usernameKey} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() &&
        !exists(/databases/$(database)/documents/usernames/$(usernameKey)) &&
        isValidUsernameClaim(usernameKey, request.resource.data);
      allow update: if isSignedIn() &&
        resource.data.uid == request.auth.uid &&
        isValidUsernameClaim(usernameKey, request.resource.data);
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /games/{gameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.whiteId == request.auth.uid;
      allow update: if isGameParticipant(gameId) &&
        (!isMoveStateUpdate() || hasValidMoveSeqTransition());
      allow delete: if isGameParticipant(gameId);

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 200;
      }

      match /voice/{voiceDocId} {
        allow read, write: if isGameParticipant(gameId);
      }

      match /voiceSessions/{sessionId} {
        allow read, write: if isGameParticipant(gameId);

        match /{candidateCollection}/{candidateId} {
          allow read, write: if isGameParticipant(gameId);
        }
      }
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    match /dms/{chatId} {
      allow read: if isDmParticipant(resource.data);
      allow create: if isDmParticipant(request.resource.data);
      allow update: if isDmParticipant(resource.data) &&
        request.resource.data.participants == resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isDmParticipant(get(/databases/$(database)/documents/dms/$(chatId)).data);
        allow create: if isDmParticipant(get(/databases/$(database)/documents/dms/$(chatId)).data) &&
          request.resource.data.senderId == request.auth.uid;
      }
    }

    match /friend_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.from == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.from == request.auth.uid ||
        resource.data.to == request.auth.uid
      );
      // Allow delete for declining/removing friends
      allow delete: if isSignedIn() && (
        resource.data.from == request.auth.uid ||
        resource.data.to == request.auth.uid
      );
    }

    match /game_challenges/{challengeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.from == request.auth.uid;
      allow update: if isSignedIn() && resource.data.to == request.auth.uid;
      allow delete: if isSignedIn() && (
        resource.data.from == request.auth.uid ||
        resource.data.to == request.auth.uid
      );
    }
  }
}
